{"type":"item.started","item":{"id":"item_49","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - <<'PY'\nfrom pathlib import Path\nfrom pypdf import PdfReader\nimport re\n\nfiles = sorted(Path('papers').glob('*.pdf'))\nkeywords = re.compile(r'(?i)(refus|sycoph|persona|personaliz|user|context|conversation|long[- ]?term|sleep|go to bed|safety|over[- ]?refus|mechanis|direction|dataset|benchmark|method|result|finding)')\nheading_re = re.compile(r'(?m)\"'^(?:'\"\\\\d+(?:\\\\.\\\\d+)*\\\\s+)?[A-Z][A-Za-z0-9 ,:;\\\\-/()]{5,90}\"'$'\"')\n\ndef clean(s):\n    s = re.sub(r'\\\\s+', ' ', s or '').strip()\n    return s\n\ndef section(text, names):\n    lower = text.lower()\n    for name in names:\n        idx = lower.find(name)\n        if idx \"'!= -1:\n            return clean(text[idx:idx+1800])\n    return '\"''\n\nfor f in files:\n    reader = PdfReader(str(f))\n    pages = []\n    for p in reader.pages:\n        try:\n            pages.append(p.extract_text() or '')\n        except Exception:\n            pages.append('')\n    text = '\\\\n'.join(pages)\n    first = clean('\\\\n'.join(pages[:2]))[:1800]\n    conclusion = section(text, ['conclusion', 'discussion', 'limitations'])[:1800]\n    headings = []\n    for m in heading_re.finditer('\\\\n'.join(pages[:8])):\n        h = clean(m.group(0))\n        if len(h.split()) <= 12 and h not in headings:\n            headings.append(h)\n        if len(headings) >= 12:\n            break\n    contexts = []\n    for m in keywords.finditer(text):\n        start = max(0, m.start()-220)\n        end = min(len(text), m.end()+420)\n        ctx = clean(text[start:end])\n        if ctx and ctx not in contexts:\n            contexts.append(ctx)\n        if len(contexts) >= 3:\n            break\n    print('\\\\n===', f.name, f'({len(reader.pages)} pages) ===')\n    print('FIRST:', first)\n    print('HEADINGS:', '; '.join(headings[:10]))\n    print('CONCL:', conclusion)\n    for i, ctx in enumerate(contexts, 1):\n        print(f'CTX{i}:', ctx)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
