{"type":"item.started","item":{"id":"item_68","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - <<'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json, os, re\n\nbase = Path('datasets')\nbase.mkdir(exist_ok=True)\n\njobs = [\n    ('Paul/XSTest', None, None, base/'xstest'),\n    ('LibrAI/do-not-answer', None, None, base/'do_not_answer'),\n    ('bench-llm/or-bench', 'or-bench-hard-1k', None, base/'or_bench_hard_1k'),\n    ('bench-llm/or-bench', 'or-bench-toxic', None, base/'or_bench_toxic'),\n    ('bench-llm/or-bench', 'or-bench-80k', None, base/'or_bench_80k'),\n    ('bowen-upenn/PersonaMem-v2', 'benchmark', 'benchmark_text', base/'personamem_v2_benchmark_text'),\n]\nsummary = []\nfor name, cfg, split, out in jobs:\n    print(f'Loading {name} config={cfg} split={split}')\n    if split:\n        ds = load_dataset(name, cfg, split=split)\n        ds.save_to_disk(str(out))\n        rows = len(ds)\n        cols = ds.column_names\n        sample_rows = [ds[i] for i in range(min(5, rows))]\n    else:\n        ds = load_dataset(name, cfg) if cfg else load_dataset(name)\n        ds.save_to_disk(str(out))\n        rows = {k: len(v) for k, v in ds.items()}\n        cols = {k: v.column_names for k, v in ds.items()}\n        first_split = next(iter(ds.keys()))\n        sample_rows = [ds[first_split][i] for i in range(min(5, len(ds[first_split])))]\n    sample_dir = out / 'samples'\n    sample_dir.mkdir(parents=True, exist_ok=True)\n    with (sample_dir / 'sample.json').open('w', encoding='utf-8') as f:\n        json.dump(sample_rows, f, indent=2, ensure_ascii=False)\n    summary.append({'name': name, 'config': cfg, 'split': split, 'location': str(out), 'rows': rows, 'columns': cols})\n\n# WildChat: stream a bounded sample and collect conversations with assistant sleep/bed/rest phrases if present.\nprint('Streaming WildChat bounded sample')\nwild_out = base / 'wildchat_sample'\nwild_out.mkdir(parents=True, exist_ok=True)\nwild = load_dataset('allenai/WildChat', split='train', streaming=True)\nsleep_re = re.compile(r'(?i)\\\\b(go to sleep|get some sleep|go to bed|go rest|bedtime|sleep now|rest now)\\\\b')\nsamples = []\nmatches = []\nfor idx, row in enumerate(wild):\n    if len(samples) < 200:\n        samples.append(row)\n    text = json.dumps(row, ensure_ascii=False)\n    if sleep_re.search(text):\n        matches.append(row)\n        if len(matches) >= 25:\n            break\n    if idx >= 20000 and len(matches) >= 5:\n        break\n    if idx >= 50000:\n        break\nfor dirname, data in [('samples', samples[:25]), ('sleep_phrase_matches', matches)]:\n    d = wild_out / dirname\n    d.mkdir(parents=True, exist_ok=True)\n    with (d / 'sample.json').open('w', encoding='utf-8') as f:\n        json.dump(data, f, indent=2, ensure_ascii=False)\nsummary.append({'name': 'allenai/WildChat', 'config': 'default', 'split': 'train streaming bounded sample', 'location': str(wild_out), 'rows': {'sampled': len(samples), 'sleep_phrase_matches': len(matches)}, 'columns': list(samples[0].keys()) if samples else []})\n\nwith (base / 'dataset_summary.json').open('w', encoding='utf-8') as f:\n    json.dump(summary, f, indent=2, ensure_ascii=False)\nprint(json.dumps(summary, indent=2, ensure_ascii=False)[:6000])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
